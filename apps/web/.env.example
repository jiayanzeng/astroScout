# Base URL of the Week-1 FastAPI service
API_BASE_URL=http://127.0.0.1:8000

# Supabase (auth + persistence) — from your project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vercel AI SDK / OpenAI — needed for /chat and the LLM reranker
OPENAI_API_KEY=
# Optional: OpenAI-compatible relay endpoint (default: https://api.openai.com/v1)
# @ai-sdk/openai reads this env var natively — no code change needed.
OPENAI_BASE_URL=

# Authenticated chat quotas (enforced atomically by Supabase migration 0006).
CHAT_REQUESTS_PER_MINUTE=6
CHAT_REQUESTS_PER_DAY=100

# Optional accounting-price overrides, in USD per million tokens. Defaults track the
# documented gpt-4o-mini and text-embedding-3-small standard prices as of 2026-07-15.
OPENAI_GPT4O_MINI_INPUT_USD_PER_MILLION=0.15
OPENAI_GPT4O_MINI_OUTPUT_USD_PER_MILLION=0.60
OPENAI_EMBEDDING_3_SMALL_INPUT_USD_PER_MILLION=0.02
OPENAI_EMBEDDING_3_SMALL_OUTPUT_USD_PER_MILLION=0

# Optional: Cohere Rerank (a real cross-encoder). In auto mode, preferred over the LLM.
COHERE_API_KEY=

# Optional explicit reranker: auto, bge, cohere, llm, or none.
# Unset preserves the default Cohere -> LLM -> pass-through dispatch.
RERANK_BACKEND=
# Optional local BGE model override (default: Xenova/bge-reranker-base).
BGE_RERANK_MODEL=
