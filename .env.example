# --- API (apps/api) ---
# NASA ADS literature token (free): https://ui.adsabs.harvard.edu/user/settings/token
ADS_TOKEN=

# RAG ingestion (write side) — only needed to run scripts/ingest_knowledge.py
OPENAI_API_KEY=
# Optional: OpenAI-compatible relay endpoint (default: https://api.openai.com/v1)
OPENAI_BASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Comma-separated web origins allowed to call the API (CORS). Default covers local dev.
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000
